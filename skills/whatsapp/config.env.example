# WhatsApp skill credentials (Green API) — copy to whatsapp/config.env and fill in.
#
#   cp skills/whatsapp/config.env.example whatsapp/config.env
#
# The scripts source whatsapp/config.env automatically (unless the vars are
# already set in the environment, which takes precedence). Keep the real file
# out of git: git-ignore `whatsapp/config.env` in the agent's folder.
#
# Get all three values from https://console.green-api.com — create an instance,
# then copy idInstance, apiTokenInstance, and the instance's apiUrl.

GREENAPI_ID_INSTANCE=1101000001
GREENAPI_API_TOKEN=
# Use the apiUrl EXACTLY as the console shows for your instance — newer
# instances live on a numbered subdomain, e.g. https://7103.api.greenapi.com
GREENAPI_API_URL=https://api.green-api.com
# Default recipient for wa_send.sh when --chat is omitted. A bare phone number
# in international format without + (e.g. 79001234567) or a full chatId
# (79001234567@c.us for a person, <id>@g.us for a group).
WHATSAPP_DEFAULT_CHAT_ID=
